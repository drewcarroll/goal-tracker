// Prisma schema for Goal Tracker.
// Connection URLs are configured in ../prisma.config.ts (migrations/introspection)
// and via the Neon driver adapter at runtime — see
// src/infrastructure/database/prismaClient.ts.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js (NextAuth) models ---
// Persisted by @auth/prisma-adapter. Field names on Account (refresh_token,
// access_token, …) are required verbatim by the adapter. IDs are uuid to stay
// consistent with `Goal.userId`, which stores the authenticated user's id.

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz(6)
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Goal tracking models ---
// A Goal is a measurable target (targetValue + freeform unit). Each goal owns
// exactly one GoalSession (its start/end timeframe) and accrues many Logs.
// Progress is derived from accumulated logs, not stored on the goal.
// Per-user scoping (userId) is enforced in application code, consistent with
// the rest of the app — see memory note on the auth model.

/// A user's goal, e.g. name "Read books", targetValue 12, unit "books".
model Goal {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.Text
  targetValue Decimal  @map("target_value") @db.Decimal(12, 4)
  unit        String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  session GoalSession?
  logs    Log[]

  @@index([userId])
  @@map("goals")
}

/// The timeframe a goal is pursued over. One per goal (one-to-one).
/// Named GoalSession to avoid colliding with the Auth.js `Session` model above.
model GoalSession {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @unique @map("goal_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  startDate DateTime @map("start_date") @db.Timestamptz(6)
  endDate   DateTime @map("end_date") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goal_sessions")
}

/// A single value logged against a goal for a specific week of its session.
/// (goalId, weekIndex) is intentionally NOT unique: multiple logs in the same
/// week accumulate toward the goal's targetValue.
model Log {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  weekIndex Int      @map("week_index")
  value     Decimal  @db.Decimal(12, 4)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, weekIndex])
  @@index([userId])
  @@map("logs")
}
