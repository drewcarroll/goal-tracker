# --- Auth.js (NextAuth) ---
# AUTH_SECRET: used to encrypt tokens/cookies. Generate with `npx auth secret`.
AUTH_SECRET=your-auth-secret
# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client).
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
# Optional: set when the host can't be auto-detected (e.g. behind a proxy).
# AUTH_URL=http://localhost:3000

# --- Supabase (goals data layer) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side only (used by infrastructure layer). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Neon Postgres (Prisma — Auth.js adapter persistence) ---
# DATABASE_URL: Neon *pooled* connection (host contains "-pooler"). Used by the
# Prisma runtime client via the Neon serverless adapter — safe for Vercel.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# DIRECT_URL: Neon *direct* (unpooled) connection. Used by `prisma migrate`
# and introspection, which can't run over the transaction-mode pooler.
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require
