# Copy to .env and fill in. See SETUP.md for where to get each value.

# --- Supabase (goals + logs storage) ---
# Supabase dashboard → Project Settings → API.
# Project URL:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Server-side only — the `service_role` key (bypasses RLS). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Shared password gate ---
# The single password that unlocks the app (single-user). Pick anything.
APP_PASSWORD=change-me
