{
  "name": "goal-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "A goal tracking application built with Next.js, TypeScript, Tailwind CSS, and Supabase following Clean Architecture.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"{src,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,mjs,ts}\"",
    "format:check": "prettier --check \"{src,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,mjs,ts}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
